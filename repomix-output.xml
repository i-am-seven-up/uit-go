    {
        public static IServiceCollection AddRabbitMqEventBus(
            this IServiceCollection services,
            IConfiguration cfg,
            string exchangeName)
        {
            services.Configure<RabbitMqOptions>(cfg.GetSection("RabbitMQ"));

            // Publisher

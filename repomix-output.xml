                                    <th scope="col">OS</th>
                                    <th scope="col">NBomber Version</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr v-for="n in nodes">
                                    <td>{{ n.NodeId }}</td>
                                    <td>{{ n.NodeInfo.NodeType.Case }}</td>
                                    <td>{{ n.AgentGroup }}</td>
                                    <td>{{ n.NodeInfo.Processor }}</td>
                                    <td>{{ n.NodeInfo.CoresCount }}</td>
                                    <td>{{ n.NodeInfo.OS }}</td>
                                    <td>{{ n.NodeInfo.NBomberVersion }}</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                </div>

            </div>
        </div>
        `
    })
    .mount("#app");
</script>
</body>
</html>
